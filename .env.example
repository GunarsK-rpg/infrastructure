# ============================================================================
# COSMERE RPG INFRASTRUCTURE ENVIRONMENT VARIABLES
# ============================================================================
#
# IMPORTANT: This is an example file. To generate secure credentials:
#   1. Run: task secrets:generate
#   2. Or run: python3 scripts/generate-secrets.py
#
# The script will create a .env file with randomly generated passwords.
# DO NOT use placeholder passwords in any environment!
# ============================================================================

# Database (internal Docker network port - host access via localhost:5435)
DB_HOST=postgres
DB_PORT=5432
# DB_SSL_MODE: disable (local dev only), require/verify-full (production)
DB_SSL_MODE=disable
POSTGRES_DB=cosmere_rpg

# PostgreSQL Superuser (for database creation)
# AUTO-GENERATED: Run 'task secrets:generate' to create secure password
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERUSER_PASSWORD=postgres_dev_pass

# Flyway Migration User (DDL rights - creates/alters tables)
# AUTO-GENERATED: Run 'task secrets:generate' to create secure password
FLYWAY_USER=cosmere_owner
FLYWAY_PASSWORD=cosmere_owner_dev_pass
FLYWAY_BASELINE_ON_MIGRATE=true
FLYWAY_LOCATIONS=filesystem:/flyway/sql,filesystem:/flyway/seeds,filesystem:/flyway/private-seeds

# Application User (CRUD rights - used by services)
# AUTO-GENERATED: Run 'task secrets:generate' to create secure password
DB_USER=cosmere_app
DB_PASSWORD=cosmere_app_dev_pass

# Redis
# AUTO-GENERATED: Run 'task secrets:generate' to create secure password
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_dev_pass

# MinIO (S3-compatible storage)
# Root user for MinIO administration
# AUTO-GENERATED: Run 'task secrets:generate' to create secure password
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_dev_pass

# Service account for file operations (limited to bucket operations only)
# AUTO-GENERATED: Run 'task secrets:generate' to create secure password
S3_ACCESS_KEY=cosmere-files-user
S3_SECRET_KEY=cosmere-files-secret-change-in-production
S3_ENDPOINT=http://minio:9000
S3_USE_SSL=false

# JWT Authentication
# AUTO-GENERATED: Run 'task secrets:generate' to create secure secret
JWT_SECRET=your-jwt-secret-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# Cookie Configuration
# COOKIE_DOMAIN: Set to ".yourdomain.com" for production, empty for localhost
# COOKIE_SECURE: true for HTTPS (production), false for HTTP (development)
# COOKIE_SAMESITE: Strict (production), Lax (development)
COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAMESITE=Lax

# SSL/TLS Certificates
# For local development with self-signed certs
TRAEFIK_CERT_DIR=./docker/traefik/certs
TLS_CERT_FILE=localhost.crt
TLS_KEY_FILE=localhost.key

# Environment
ENVIRONMENT=development

# Logging Configuration (for all Go services)
# LOG_LEVEL: debug (verbose), info (normal), warn (warnings only), error (errors only)
# LOG_FORMAT: json (for production), text (human-readable for development)
# LOG_SOURCE: true (add file:line to logs, dev only), false (production)
LOG_LEVEL=info
LOG_FORMAT=json
LOG_SOURCE=false

# Service Ports
PUBLIC_API_PORT=8182
PUBLIC_WEB_PORT=8180

# Go Service Configuration
GIN_MODE=release
MAX_BODY_SIZE=1048576

# CORS - Allowed origins for each service
ALLOWED_ORIGINS_PUBLIC=https://localhost:8543,http://localhost:8100

# Web Frontend
VITE_PUBLIC_API_URL=https://localhost:8543/api/v1
VITE_PUBLIC_AUTH_URL=https://localhost:8443/auth/v1

# File Upload Configuration
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/jpg,image/png,image/gif,image/webp,application/pdf
